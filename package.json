{
  "tyn-es": {
    "exclude": [
      ".trash",
      ".wrangler",
      ".stryker-tmp",
      ".stryker-system-tmp"
    ]
  },
  "name": "mcp-knowledge-server",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rudavko/lore-mcp.git"
  },
  "author": "Andrii Rudavko",
  "homepage": "https://github.com/rudavko/lore-mcp#readme",
  "scripts": {
    "deploy": "node scripts/deployWorker.js",
    "build-hash": "node scripts/buildHash.js",
    "install-workflow": "bun scripts/installWorkflow.js",
    "loc:src": "node scripts/listCodeLoc.js src",
    "dev": "wrangler dev",
    "format": "oxfmt --write .",
    "lint": "tyn-es .",
    "lint:fix": "oxlint --fix",
    "start": "wrangler dev",
    "cf-typegen": "wrangler types",
    "type-check": "tsc --noEmit",
    "check": "oxlint . --ignore-pattern .stryker-tmp --ignore-pattern .stryker-system-tmp",
    "test": "bun test",
    "mutate": "bun scripts/runStryker.js",
    "mutate:system": "bun ./node_modules/@stryker-mutator/core/bin/stryker.js run stryker.system.config.mjs",
    "mutate:legacy": "bun scripts/runMutationSuite.js"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.2.3",
    "@simplewebauthn/server": "^13.2.2",
    "agents": "^0.4.0",
    "hono": "^4.11.9",
    "qrcode-svg": "^1.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@stryker-mutator/core": "9.6.0",
    "@types/bun": "^1.3.9",
    "oxfmt": "^0.31.0",
    "oxlint": "^1.46.0",
    "typescript": "5.9.3",
    "wrangler": "^4.64.0"
  },
  "cloudflare": {
    "bindings": {
      "ACCESS_PASSPHRASE": {
        "description": "Passphrase required on /authorize to approve OAuth access."
      },
      "OAUTH_KV": {
        "description": "Stores OAuth clients/codes/tokens and auth guard state."
      },
      "DB": {
        "description": "Primary database for knowledge entries, triples, and transactions."
      },
      "AI": {
        "description": "Workers AI binding for generating text embeddings (bge-base-en-v1.5)."
      },
      "VECTORIZE_INDEX": {
        "description": "Vectorize index for semantic similarity search over knowledge entries.",
        "index_name": "lore-mcp-embeddings",
        "dimensions": 768,
        "metric": "cosine"
      }
    }
  }
}
