{
  "tyn-es": {
    "exclude": [
      ".trash",
      ".wrangler",
      ".stryker-tmp",
      ".stryker-system-tmp"
    ]
  },
  "name": "lore-mcp",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./package.json": "./package.json",
    "./admin.orch.1.js": "./src/admin.orch.1.js",
    "./auth.orch.1.js": "./src/auth.orch.1.js",
    "./auth-shared.pure.js": "./src/auth-shared.pure.js",
    "./config.pure.js": "./src/config.pure.js",
    "./db/summary.pure.js": "./src/db/summary.pure.js",
    "./totp.pure.js": "./src/totp.pure.js",
    "./webauthn.pure.js": "./src/webauthn.pure.js",
    "./domain/*.js": "./src/domain/*.js",
    "./lib/*.js": "./src/lib/*.js",
    "./templates/*.js": "./src/templates/*.js",
    "./wiring/*.js": "./src/wiring/*.js",
    "./index-runtime-*.js": "./src/index-runtime-*.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rudavko/lore-mcp.git"
  },
  "author": "Andrii Rudavko",
  "homepage": "https://github.com/rudavko/lore-mcp#readme",
  "scripts": {
    "format": "oxfmt --write .",
    "lint": "tyn-es .",
    "lint:fix": "oxlint --fix",
    "type-check": "tsc --noEmit",
    "check": "oxlint . --ignore-pattern .stryker-tmp --ignore-pattern .stryker-system-tmp",
    "test": "bun test",
    "mutate": "bun scripts/runStryker.js",
    "mutate:system": "bun ./node_modules/@stryker-mutator/core/bin/stryker.js run stryker.system.config.mjs"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@stryker-mutator/core": "9.6.0",
    "@types/bun": "^1.3.9",
    "oxfmt": "^0.31.0",
    "oxlint": "^1.46.0",
    "typescript": "5.9.3"
  }
}
