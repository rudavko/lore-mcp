{
  "tyn-es": {
    "exclude": [
      ".trash",
      ".wrangler",
      ".stryker-tmp",
      ".stryker-system-tmp"
    ]
  },
  "name": "mcp-knowledge-server",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rudavko/lore-mcp.git"
  },
  "author": "Andrii Rudavko",
  "homepage": "https://github.com/rudavko/lore-mcp#readme",
  "scripts": {
    "loc:src": "node scripts/listCodeLoc.js src",
    "format": "oxfmt --write .",
    "lint": "tyn-es .",
    "lint:fix": "oxlint --fix",
    "type-check": "tsc --noEmit",
    "check": "oxlint . --ignore-pattern .stryker-tmp --ignore-pattern .stryker-system-tmp",
    "test": "bun test",
    "mutate": "bun scripts/runStryker.js",
    "mutate:system": "bun ./node_modules/@stryker-mutator/core/bin/stryker.js run stryker.system.config.mjs",
    "mutate:legacy": "bun scripts/runMutationSuite.js"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@stryker-mutator/core": "9.6.0",
    "@types/bun": "^1.3.9",
    "oxfmt": "^0.31.0",
    "oxlint": "^1.46.0",
    "typescript": "5.9.3"
  }
}
